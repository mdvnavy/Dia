# Copy to .env and fill in. Either key enables live Gemini agent runs.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Make MCP Toolbox (optional): the agent connects to this curated MCP server
# and gains its published scenario tools. Leave unset to run without it.
MAKE_MCP_URL=
MAKE_MCP_TOKEN=
# GCP-managed MCP server (optional): a Google Cloud MCP endpoint, e.g.
# https://monitoring.googleapis.com/mcp. Auth comes from ADC (gcloud auth
# application-default login), not an API key. Leave unset to run without it.
GCP_MCP_URL=
DIA_AGENT_MCP_MODE=auto
DIA_AGENT_ALLOW_GCP_MCP_TOOLS=
